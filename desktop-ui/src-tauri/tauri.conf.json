{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ElisaCalculator",
  "version": "0.1.0",
  "identifier": "com.zhouc.elisacalculator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run tauri:build:bridge"
  },
  "app": {
    "windows": [
      {
        "title": "ELISA Calculator",
        "width": 1360,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "useLocalToolsDir": true,
    "resources": [
      "../../elisa_calculator",
      "../../ElisaCalculator.py",
      "resources/bridge/elisa_bridge.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "ELISA Calculator"
      }
    }
  }
}
